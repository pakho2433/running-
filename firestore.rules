rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStudent() {
      return request.resource.data.classId is string
        && request.resource.data.studentId is string
        && request.resource.data.studentId.size() >= 1
        && request.resource.data.studentId.size() <= 20
        && request.resource.data.booksCount is int
        && request.resource.data.booksCount >= 0
        && request.resource.data.distance is number
        && request.resource.data.distance >= 0;
    }

    match /students/{studentKey} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validStudent();
      allow delete: if false;
    }

    match /bookLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }
  }
}
