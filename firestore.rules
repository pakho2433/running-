rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStudent() {
      return signedIn()
        && profile().role == "student"
        && profile().active != false
        && profile().classId is string
        && profile().studentId is string;
    }

    function isTeacher() {
      return signedIn()
        && request.auth.token.teacher == true
        && request.auth.token.role == "teacher"
        && profile().role == "teacher"
        && profile().active != false;
    }

    function myStudentKey() {
      return profile().classId + "__" + profile().studentId;
    }

    function validStudentIdentity(data, studentKey) {
      return isStudent()
        && studentKey == myStudentKey()
        && data.classId == profile().classId
        && data.studentId == profile().studentId;
    }

    function validStudentNumbers(data) {
      return data.booksCount is int
        && data.booksCount >= 0
        && data.distance is number
        && data.distance >= 0
        && (!('dailyBooksCount' in data)
          || (data.dailyBooksCount is int
            && data.dailyBooksCount >= 0
            && data.dailyBooksCount <= 5))
        && (!('dailyDateKey' in data)
          || data.dailyDateKey == ""
          || (data.dailyDateKey is string
            && data.dailyDateKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')));
    }

    function validStudentCreate(data, studentKey) {
      return validStudentIdentity(data, studentKey)
        && validStudentNumbers(data)
        && data.booksCount == 0
        && data.distance == 0;
    }

    function identityRefreshOnly() {
      return request.resource.data.booksCount == resource.data.booksCount
        && request.resource.data.distance == resource.data.distance
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["classId", "studentId", "updatedAt"]);
    }

    function validDailyCounter() {
      return (
        (!('dailyDateKey' in resource.data) || !('dailyBooksCount' in resource.data))
        && request.resource.data.dailyBooksCount == 1
      ) || (
        request.resource.data.dailyDateKey == resource.data.dailyDateKey
        && request.resource.data.dailyBooksCount == resource.data.dailyBooksCount + 1
        && request.resource.data.dailyBooksCount <= 5
      ) || (
        request.resource.data.dailyDateKey != resource.data.dailyDateKey
        && request.resource.data.dailyBooksCount == 1
      );
    }

    function logMatches(logId, sequence) {
      let log = getAfter(/databases/$(database)/documents/bookLogs/$(logId)).data;
      return log.studentKey == myStudentKey()
        && log.classId == profile().classId
        && log.studentId == profile().studentId
        && log.submissionDateKey == request.resource.data.dailyDateKey
        && log.dailySequence == sequence
        && log.distanceAwarded == request.resource.data.distance - resource.data.distance;
    }

    function matchingLogExists() {
      let key = myStudentKey();
      let date = request.resource.data.dailyDateKey;
      let sequence = request.resource.data.dailyBooksCount;
      return (sequence == 1 && logMatches(key + "__" + date + "__1", 1))
        || (sequence == 2 && logMatches(key + "__" + date + "__2", 2))
        || (sequence == 3 && logMatches(key + "__" + date + "__3", 3))
        || (sequence == 4 && logMatches(key + "__" + date + "__4", 4))
        || (sequence == 5 && logMatches(key + "__" + date + "__5", 5));
    }

    function validReadingIncrement() {
      return request.resource.data.booksCount == resource.data.booksCount + 1
        && request.resource.data.distance >= resource.data.distance + 10
        && request.resource.data.distance <= resource.data.distance + 120
        && request.resource.data.dailyBooksCount is int
        && request.resource.data.dailyDateKey is string
        && request.resource.data.dailyDateKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && validDailyCounter()
        && matchingLogExists()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "classId", "studentId", "booksCount", "distance", "lastBook",
          "lastAuthor", "dailyDateKey", "dailyBooksCount", "updatedAt"
        ]);
    }

    function validStudentUpdate(studentKey) {
      return validStudentIdentity(request.resource.data, studentKey)
        && validStudentNumbers(request.resource.data)
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.studentId == resource.data.studentId
        && (identityRefreshOnly() || validReadingIncrement());
    }

    function validPublicStudent(data, studentKey) {
      let privateData = getAfter(/databases/$(database)/documents/students/$(studentKey)).data;
      return validStudentIdentity(data, studentKey)
        && data.keys().hasOnly(["classId", "studentId", "booksCount", "distance", "updatedAt"])
        && data.booksCount == privateData.booksCount
        && data.distance == privateData.distance;
    }

    function deterministicLogId(data, logId) {
      return (data.dailySequence == 1 && logId == data.studentKey + "__" + data.submissionDateKey + "__1")
        || (data.dailySequence == 2 && logId == data.studentKey + "__" + data.submissionDateKey + "__2")
        || (data.dailySequence == 3 && logId == data.studentKey + "__" + data.submissionDateKey + "__3")
        || (data.dailySequence == 4 && logId == data.studentKey + "__" + data.submissionDateKey + "__4")
        || (data.dailySequence == 5 && logId == data.studentKey + "__" + data.submissionDateKey + "__5");
    }

    function validBookLog(data, logId) {
      let studentAfter = getAfter(/databases/$(database)/documents/students/$(data.studentKey)).data;
      return isStudent()
        && deterministicLogId(data, logId)
        && data.studentKey == myStudentKey()
        && data.classId == profile().classId
        && data.studentId == profile().studentId
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 80
        && data.author is string
        && data.author.size() >= 1
        && data.author.size() <= 80
        && data.distanceAwarded is int
        && data.distanceAwarded >= 10
        && data.distanceAwarded <= 120
        && data.submissionDateKey is string
        && data.submissionDateKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.dailySequence is int
        && data.dailySequence >= 1
        && data.dailySequence <= 5
        && studentAfter.dailyDateKey == data.submissionDateKey
        && studentAfter.dailyBooksCount == data.dailySequence;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /students/{studentKey} {
      allow read: if isTeacher() || (isStudent() && studentKey == myStudentKey());
      allow create: if validStudentCreate(request.resource.data, studentKey);
      allow update: if validStudentUpdate(studentKey);
      allow delete: if false;
    }

    match /publicStudents/{studentKey} {
      allow read: if isTeacher() || (isStudent() && resource.data.classId == profile().classId);
      allow create, update: if validPublicStudent(request.resource.data, studentKey);
      allow delete: if false;
    }

    match /bookLogs/{logId} {
      allow read: if isTeacher() || (isStudent() && resource.data.studentKey == myStudentKey());
      allow create: if validBookLog(request.resource.data, logId);
      allow update, delete: if false;
    }

    match /dailyRecommendations/{dateKey} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
