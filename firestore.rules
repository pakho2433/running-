rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStudent() {
      return request.resource.data.classId is string
        && request.resource.data.studentId is string
        && request.resource.data.studentId.size() >= 1
        && request.resource.data.studentId.size() <= 20
        && request.resource.data.booksCount is int
        && request.resource.data.booksCount >= 0
        && request.resource.data.distance is number
        && request.resource.data.distance >= 0
        && (!('dailyBooksCount' in request.resource.data)
          || (request.resource.data.dailyBooksCount is int
            && request.resource.data.dailyBooksCount >= 0
            && request.resource.data.dailyBooksCount <= 5))
        && (!('dailyDateKey' in request.resource.data)
          || request.resource.data.dailyDateKey is string);
    }

    function validRecommendation() {
      return request.resource.data.dateKey is string
        && request.resource.data.dateKey.size() == 10
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 120
        && request.resource.data.author is string
        && request.resource.data.author.size() >= 1
        && request.resource.data.author.size() <= 100
        && request.resource.data.coverUrl is string
        && request.resource.data.coverUrl.size() <= 600
        && request.resource.data.grade is string
        && request.resource.data.grade.size() <= 40
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 600
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.platformUrl is string
        && request.resource.data.platformUrl.size() >= 1
        && request.resource.data.platformUrl.size() <= 600
        && request.resource.data.published is bool;
    }

    match /students/{studentKey} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validStudent();
      allow delete: if false;
    }

    match /bookLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    match /dailyRecommendations/{dateKey} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validRecommendation();
      allow delete: if signedIn();
    }
  }
}
